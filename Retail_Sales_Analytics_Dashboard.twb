      <column caption='Sales revenue' datatype='real' name='[Calculation_3242189942685696]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[price]* [Sales Volume]' />
      </column>
      <column caption='Total sales per category' datatype='integer' name='[Calculation_3242189942841345]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED  [Product category]: SUM([Sales Volume])}' />
      </column>
      <column caption='Promotion sales ratio' datatype='real' name='[Calculation_3242189947854850]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Sales Volume]/ [Calculation_3242189942841345]' />
      </column>
      <column caption='Average sales per product' datatype='real' name='[Calculation_3242189952978947]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ INCLUDE [name]: AVG([Sales Volume]) }' />
      </column>
      <column caption='Sales revenue by category' datatype='real' name='[Calculation_3242189954342916]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [Product category]:SUM([Calculation_3242189942685696]) }' />
      </column>
      <column caption='Average sales revenue per product' datatype='real' name='[Calculation_3242189959421957]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ INCLUDE [name]: AVG([Calculation_3242189942685696])}' />
      </column>
      <column caption='Sales of jackets' datatype='integer' name='[Calculation_3242189960884230]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Product category] = &apos;jackets&apos; THEN [Sales Volume]&#13;&#10;END' />
      </column>
      <column aggregation='Attribute' caption='Exclude jacket sales' datatype='integer' name='[Calculation_3242189964922892]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ EXCLUDE [Product category]: SUM([Calculation_3242189960884230]) }' />
      </column>
      <column caption='Sales Difference from jackets ' datatype='integer' name='[Calculation_3242189965176845]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Sales Volume]) - SUM([Calculation_3242189964922892])' />
      </column>
      <column caption='chosen category' datatype='string' name='[Calculation_3242189969035278]' role='dimension' type='nominal'>
